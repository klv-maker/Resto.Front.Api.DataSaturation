<Window x:Class="Resto.Front.Api.DataSaturation.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Resto.Front.Api.DataSaturation.Views"
        mc:Ignorable="d"
        WindowStyle="None"
        WindowState="Normal"
        Title="SettingsWindow" Height="1000" Width="500">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="6*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="4*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="8*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <ListBox Grid.Row="0"
                     SelectedItem="{Binding SelectedAddress}"
                     ItemsSource="{Binding AddressViewModels}"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel>
                            <TextBlock Text="{Binding Path=AddressNumber}"
                                       FontSize="24"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Margin="5,0,5,0"/>
                            <TextBox FontSize="25"
                                     Margin="0,0,5,0"
                                     VerticalAlignment="Stretch"
                                     MinWidth="350"
                                     HorizontalAlignment="Stretch"
                                     Text="{Binding Path=AddressApi}"/>
                            <Button Content="-"
                                    Margin="0,0,5,0"
                                    HorizontalAlignment="Right"
                                    Grid.Column="0"
                                    Width="30"
                                    Height="30"
                                    FontSize="25"
                                    FontWeight="Medium"
                                    Background="LightGray"
                                    Command="{Binding RemoveCommand}"
                                    VerticalAlignment="Center"
                                    VerticalContentAlignment="Center"/>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="8*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Label Content="Добавить новый адрес апи"
                       Height="50"
                       FontSize="15"
                       VerticalContentAlignment="Center"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"/>
                <Button Content="+"
                        Grid.Column="1"
                        Width="40"
                        Height="40"
                        FontSize="25"
                        HorizontalAlignment="Center"
                        FontWeight="Medium"
                        Background="LightGray"
                        Command="{Binding AddCommand}"
                        VerticalContentAlignment="Top"/>
            </Grid>
        </Grid>
        <DockPanel Grid.Row="1">
            <Label Content="QR-код:"
                    Height="50"
                    FontSize="15"
                    VerticalContentAlignment="Center"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left"
                    Margin="6,0,0,0" />
            <Border BorderBrush="Black"
                    Height="40"
                    BorderThickness="1"
                    Margin="5,0,5,0"
                    HorizontalAlignment="Right"
                    Width="400">
                <TextBox Text="{Binding DataQR}"
                         FontSize="25"
                         Height="40"
                         HorizontalContentAlignment="Center"
                         VerticalContentAlignment="Center"
                         TextWrapping="NoWrap"
                         Width="400"/>
            </Border>
        </DockPanel>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="10*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label Content="Включить отправку чеков:"
                   Height="50"
                   FontSize="15"
                   VerticalContentAlignment="Center"
                   HorizontalAlignment="Right"/>
            <CheckBox Content=""
                      Grid.Column="1"
                      VerticalAlignment="Center" 
                      Checked="CheckBox_Checked"
                      VerticalContentAlignment="Center"
                      IsChecked="{Binding EnableOrdersService}" 
                      Height="15"
                      Width="20" />
        </Grid>
        <DockPanel Grid.Row="3">
            <Label Content="Через сколько автоматически сменить контент:"
                   Height="50"
                   FontSize="15"
                   HorizontalAlignment="Left"
                   VerticalContentAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="5,0,5,0"/>
            <Border BorderBrush="Black"
                    Height="40"
                    BorderThickness="1"
                    Margin="5,0,5,0"
                    Width="140">
                <TextBox Text="{Binding SwitchMediaTime}"
                         FontSize="25"
                         HorizontalContentAlignment="Center"
                         VerticalContentAlignment="Center"
                         TextChanged="TextBox_TextChanged"
                         PreviewTextInput="TextBox_PreviewTextInput"
                         Height="40"
                         Width="140"                 
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
            </Border>
        </DockPanel>
        <Border Grid.Row="4"
                BorderBrush="Black"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.8*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel>
                    <Label Content="IIKO Card"
                           Height="50"
                           FontSize="15"
                           VerticalAlignment="Stretch"
                           HorizontalAlignment="Right"/>
                </DockPanel>
                <DockPanel Grid.Row="1">
                    <Label Content="Адрес апи iiko card:"
                           Height="50"
                           FontSize="15"
                           HorizontalAlignment="Right"
                           VerticalContentAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="5,0,5,0"/>
                    <Border BorderBrush="Black"
                            Height="40"
                            BorderThickness="1"
                            Margin="5,0,5,0"
                            HorizontalAlignment="Right"
                            Width="330">
                        <TextBox Text="{Binding IikoCard.Address}"
                                 FontSize="25"
                                 HorizontalContentAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 Height="40"
                                 TextWrapping="NoWrap"
                                 Width="330"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                    </Border>
                </DockPanel>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.3*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0"
                           Content="Логин:"
                           Height="50"
                           FontSize="15"
                           HorizontalAlignment="Right"
                           VerticalContentAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="5,0,5,0"/>
                    <Border BorderBrush="Black"
                            Height="40"
                            BorderThickness="1"
                            Margin="5,0,5,0"
                            Width="140"
                            Grid.Column="1">
                        <TextBox Text="{Binding IikoCard.User}"
                                 FontSize="25"
                                 HorizontalContentAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 Height="40"
                                 Width="140"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                    </Border>
                </Grid>
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.3*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Label Content="Пароль:"
                           Height="50"
                           FontSize="15"
                           HorizontalAlignment="Right"
                           VerticalContentAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="5,0,5,0"
                           Grid.Column="0"/>
                    <Border BorderBrush="Black"
                            Height="40"
                            BorderThickness="1"
                            Margin="5,0,5,0"
                            Width="140"
                            Grid.Column="1">
                        <TextBox Text="{Binding IikoCard.Secret}"
                                 FontSize="25"
                                 HorizontalContentAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 Height="40"
                                 Width="140"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                    </Border>
                </Grid>
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Label Content="Организация:"
                           Height="50"
                           FontSize="15"
                           HorizontalAlignment="Right"
                           VerticalContentAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="5,0,5,0"
                           Grid.Column="0"/>
                    <Border BorderBrush="Black"
                            Height="40"
                            BorderThickness="1"
                            Margin="5,0,5,0"
                            HorizontalAlignment="Right"
                            Grid.Column="1"
                            Width="370">
                        <TextBox Text="{Binding IikoCard.Organization}"
                                 FontSize="25"
                                 HorizontalContentAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 Height="40"
                                 TextWrapping="NoWrap"
                                 Width="370"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <Grid Grid.Row="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.3*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0"
                           Content="Логин локального iiko card:"
                           Height="50"
                           FontSize="15"
                           HorizontalAlignment="Right"
                           VerticalContentAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="5,0,5,0"/>
                    <Border BorderBrush="Black"
                            Height="40"
                            BorderThickness="1"
                            Margin="5,0,5,0"
                            Width="140"
                            Grid.Column="1">
                        <TextBox Text="{Binding IikoCard.UserLocal}"
                                 FontSize="25"
                                 HorizontalContentAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 Height="40"
                                 Width="140"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                    </Border>
                </Grid>
                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.3*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Label Content="Пароль локального iiko card:"
                           Height="50"
                           FontSize="15"
                           HorizontalAlignment="Right"
                           VerticalContentAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="5,0,5,0"
                           Grid.Column="0"/>
                    <Border BorderBrush="Black"
                            Height="40"
                            BorderThickness="1"
                            Margin="5,0,5,0"
                            Width="140"
                            Grid.Column="1">
                        <TextBox Text="{Binding IikoCard.SecretLocal}"
                                 FontSize="25"
                                 HorizontalContentAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 Height="40"
                                 Width="140"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Grid>
        </Border>
        <Grid Grid.Row="5" Margin="5,0,5,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Content="Cancel"
                    HorizontalAlignment="Left"
                    Grid.Column="0"
                    Width="100"
                    Height="50"
                    FontSize="25"
                    FontWeight="Medium"
                    Background="Red"
                    Command="{Binding CancelCommand}"
                    VerticalAlignment="Center"/>
            <Button Content="Save"
                    Margin="10,0,0,0"
                    Grid.Column="1"
                    Width="100"
                    Height="50"
                    FontSize="25"
                    FontWeight="Medium"
                    Background="#32CD32"
                    Command="{Binding SaveCommand}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>
