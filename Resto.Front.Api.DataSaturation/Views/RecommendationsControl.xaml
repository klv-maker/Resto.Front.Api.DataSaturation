<UserControl x:Class="Resto.Front.Api.DataSaturation.Views.RecommendationsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="IIKOStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{StaticResource MainBgBrush}" Width="600">
        <DockPanel Margin="10,30,30,30">
            <TextBlock DockPanel.Dock="Top" Text="Вам как обычно?" Foreground="White" Margin="0,0,0,20" Opacity="0.6"/>
            <ListBox ItemsSource="{Binding Recommendations}" Background="Transparent" BorderThickness="0">
            </ListBox>
        </DockPanel>
    </Border>
</UserControl>