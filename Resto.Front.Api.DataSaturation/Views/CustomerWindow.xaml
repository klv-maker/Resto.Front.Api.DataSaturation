<Window x:Class="Resto.Front.Api.DataSaturation.Views.CustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Resto.Front.Api.DataSaturation.Views"
        Title="Customer Info" Height="700" SizeToContent="Width" 
        WindowStyle="None" WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MainBgBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="IIKOStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="75"/>
        </Grid.RowDefinitions>

        <Border Background="#252525" Padding="25,12">
            <TextBlock Text="{Binding StoreAddress, FallbackValue='Хользунова, 6 СТ МСК'}" Foreground="#999"/>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <local:CustomerDetailsControl DataContext="{Binding CustomerDetailsViewModel}"/>
            <local:RecommendationsControl 
                Visibility="{Binding IsActiveRightColumn, Converter={StaticResource BoolToVis}, FallbackValue=Visible}"/>
        </StackPanel>

        <UniformGrid Grid.Row="2" Columns="5">
            <Button Style="{DynamicResource IikoBottomButtonStyle}"
                    Content="&lt; НАЗАД"                    
                    Command="{Binding ReturnCommand}"/>
            <Button Style="{DynamicResource IikoBottomButtonStyle}" Content="ИНФОРМАЦИЯ О ГОСТЕ" 
                    Background="{DynamicResource ActiveTabBrush}" Foreground="Black" FontWeight="Bold"/>
            <!--<Button Style="{DynamicResource IikoBottomButtonStyle}" Content="ИСТОРИЯ"/>
            <Button Style="{DynamicResource IikoBottomButtonStyle}" Content="БОНУСЫ"/>
            <Button Style="{DynamicResource IikoBottomButtonStyle}" Content="ПРИВИЛЕГИИ"/>-->
        </UniformGrid>
    </Grid>
</Window>