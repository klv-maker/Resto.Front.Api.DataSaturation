<Window x:Class="Resto.Front.Api.DataSaturation.MindBox.Views.MindBoxSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Resto.Front.Api.DataSaturation.MindBox.Views"
        mc:Ignorable="d"
        WindowStyle="None"
        WindowState="Normal"
        Title="SettingsWindow" Height="200" Width="700">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <StackPanel Orientation="Vertical">
                <DockPanel>
                    <Label Content="Адрес апи:"
                           Height="50"
                           FontSize="15"
                           VerticalContentAlignment="Center"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="6,0,0,0" />
                    <Border BorderBrush="Black"
                            Height="40"
                            BorderThickness="1"
                            Margin="5,0,5,0"
                            HorizontalAlignment="Right"
                            Width="600">
                        <TextBox Text="{Binding AddressApi}"
                                 FontSize="25"
                                 TextWrapping="NoWrap"
                                 Width="600"/>
                    </Border>
                </DockPanel>
                <DockPanel>
                    <Label Content="Ключ:"
                           Height="50"
                           FontSize="15"
                           VerticalContentAlignment="Center"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="6,0,0,0" />
                    <Border BorderBrush="Black"
                            Height="40"
                            BorderThickness="1"
                            Margin="5,0,5,0"
                            HorizontalAlignment="Right"                            
                            Width="600">
                        <TextBox Text="{Binding Key}"
                                 FontSize="25"
                                 TextWrapping="NoWrap"
                                 Width="600"/>
                    </Border>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1" Margin="5,0,5,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Content="Cancel"
                    HorizontalAlignment="Left"
                    Grid.Column="0"
                    Width="100"
                    Height="50"
                    FontSize="25"
                    FontWeight="Medium"
                    Background="Red"
                    Command="{Binding CancelCommand}"
                    VerticalAlignment="Center"/>
            <Button Content="Save"
                    Margin="10,0,0,0"
                    Grid.Column="1"
                    Width="100"
                    Height="50"
                    FontSize="25"
                    FontWeight="Medium"
                    Background="#32CD32"
                    Command="{Binding SaveCommand}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>
